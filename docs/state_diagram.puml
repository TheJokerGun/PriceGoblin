@startuml StateDiagram
[*] --> Active : Tracking created

state Active {
  [*] --> Monitoring
  Monitoring --> PriceChecked : check-price requested
  PriceChecked --> Monitoring : price stored

  PriceChecked --> TargetReached : price <= target_price
  TargetReached --> NotificationCooldown : notification sent
  NotificationCooldown --> Monitoring : cooldown elapsed
  TargetReached --> Monitoring : notification skipped (cooldown/epsilon)
}

Active --> Paused : PATCH /api/tracking/{id}/active (false)
Paused --> Active : PATCH /api/tracking/{id}/active (true)

Active --> Removed : DELETE /api/products/{id}
Paused --> Removed : DELETE /api/products/{id}
Removed --> [*]
@enduml
